#!/usr/bin/env python3
"""Browse a YouTube channel's recent videos.

Usage:
    yt-channel CHANNEL [-n LIMIT]

CHANNEL can be:
  - A full URL: https://www.youtube.com/@handle or /channel/UCXXX
  - A handle: @handle
  - A channel name: search for it automatically
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys


def _run(cmd: list[str], *, timeout: int = 120) -> subprocess.CompletedProcess[str]:
    """Run a subprocess and return the result."""
    return subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=timeout,
    )


def _format_duration(seconds: float | int | None) -> str:
    """Format seconds into HH:MM:SS or MM:SS."""
    if not seconds:
        return "?"
    s = int(seconds)
    h, remainder = divmod(s, 3600)
    m, sec = divmod(remainder, 60)
    if h > 0:
        return f"{h}:{m:02d}:{sec:02d}"
    return f"{m}:{sec:02d}"


def _format_count(n: int | None) -> str:
    """Format a large number with K/M suffix."""
    if n is None:
        return "?"
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}K"
    return str(n)


def _format_date(date_str: str | None) -> str:
    """Format YYYYMMDD to YYYY-MM-DD."""
    if not date_str or len(date_str) != 8:
        return date_str or "?"
    return f"{date_str[:4]}-{date_str[4:6]}-{date_str[6:]}"


def _resolve_channel_url(channel_input: str) -> str | None:
    """Resolve channel input to a channel URL.

    If it's already a URL or @handle, use directly.
    Otherwise, search for a video by the name and extract channel_url.
    """
    # Already a full URL
    if "youtube.com/" in channel_input or "youtu.be/" in channel_input:
        # Ensure it ends with /videos for playlist listing
        url = channel_input.rstrip("/")
        if not url.endswith("/videos"):
            url += "/videos"
        return url

    # Handle @handle format
    if channel_input.startswith("@"):
        return f"https://www.youtube.com/{channel_input}/videos"

    # Search for a video to find the channel
    print(f"Searching for channel: {channel_input}...", file=sys.stderr)
    result = _run([
        "uvx", "yt-dlp",
        "--js-runtimes", "node",
        "--remote-components", "ejs:github",
        f"ytsearch1:{channel_input}",
        "--dump-json", "--no-download",
    ])
    if result.returncode != 0:
        print(f"Error searching for channel: {result.stderr.strip()}", file=sys.stderr)
        return None

    try:
        meta = json.loads(result.stdout)
    except json.JSONDecodeError:
        print("Error: failed to parse search result", file=sys.stderr)
        return None

    channel_url = meta.get("channel_url")
    if not channel_url:
        # Try uploader_url as fallback
        channel_url = meta.get("uploader_url")

    if channel_url:
        channel_name = meta.get("channel", meta.get("uploader", "Unknown"))
        print(f"Found channel: {channel_name}", file=sys.stderr)
        return channel_url.rstrip("/") + "/videos"

    print("Error: could not find channel URL from search result", file=sys.stderr)
    return None


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Browse a YouTube channel's recent videos"
    )
    parser.add_argument("channel", help="Channel URL, @handle, or name to search")
    parser.add_argument(
        "-n", "--limit",
        type=int,
        default=10,
        help="Number of videos to list (default: 10)",
    )
    args = parser.parse_args()

    # Resolve channel URL
    channel_url = _resolve_channel_url(args.channel)
    if not channel_url:
        sys.exit(1)

    # Fetch video list
    print("Fetching videos from channel...", file=sys.stderr)
    result = _run([
        "uvx", "yt-dlp",
        "--js-runtimes", "node",
        "--remote-components", "ejs:github",
        channel_url,
        "--flat-playlist",
        "--dump-json",
        "--no-download",
        "--playlist-end", str(args.limit),
    ], timeout=180)

    if result.returncode != 0:
        print(f"Error fetching channel videos: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)

    # Parse JSONL output (one JSON object per line)
    videos = []
    channel_name = None
    for line in result.stdout.strip().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
            videos.append(entry)
            if not channel_name:
                channel_name = entry.get("channel", entry.get("uploader"))
        except json.JSONDecodeError:
            continue

    if not videos:
        print("No videos found.")
        return

    # Print header
    print(f"# {channel_name or 'Channel'}\n")
    print(f"Showing {len(videos)} most recent videos:\n")

    # Print video list
    for i, v in enumerate(videos, 1):
        title = v.get("title", "Unknown")
        date = _format_date(v.get("upload_date"))
        duration = _format_duration(v.get("duration"))
        views = _format_count(v.get("view_count"))
        url = v.get("url") or v.get("webpage_url", "")
        if url and not url.startswith("http"):
            url = f"https://www.youtube.com/watch?v={url}"

        print(f"{i}. **{title}**")
        print(f"   {date} | {duration} | {views} views")
        print(f"   {url}")
        print()


if __name__ == "__main__":
    main()
